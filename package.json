{
  "name": "chatgpt-auto-login",
  "version": "1.0.0",
  "description": "Automated ChatGPT login via Gmail with TOTP 2FA support",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "web": "node server/index.js",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "test": "node --test \"__tests__/*.test.js\" \"server/__tests__/*.test.js\" \"server/proxy/__tests__/*.test.js\" \"server/liveness/__tests__/*.test.js\"",
    "test:py": "py -3 -m unittest discover tests"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "csv-parse": "^5.6.0",
    "express": "^5.2.1",
    "https-proxy-agent": "^9.0.0",
    "imapflow": "^1.3.3",
    "jsonwebtoken": "^9.0.3",
    "node-stream-zip": "^1.15.0",
    "otplib": "^12.0.1",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "socket.io": "^4.8.3",
    "sql.js": "^1.14.1",
    "tar-fs": "^3.1.2",
    "undici": "^8.3.0",
    "ws": "^8.20.1"
  }
}
